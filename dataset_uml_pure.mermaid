classDiagram
    %% 外部依赖
    class IterableDataset {
        <<torch.utils.data>>
        +__iter__()
    }
    
    %% 抽象基类：Reader
    class Reader {
        <<abstract>>
        - source: Union[List[str], str]
        +__iter__()
    }
    
    %% 具体Reader实现
    class ParquetReader {
        +__init__(source)
        +__iter__()
        +_parser(row, filename)
        +load_parquet(path)
    }
    class JsonlReader {
        +__init__(source)
        +__iter__()
        +_parser(row, filename)
        +load_parquet(path)
    }
    
    %% 基础数据集类
    
    class DistributedDataset {
        <<abstract>>
        -rank: int
        -world_size: int
        -num_workers: int
        -seed: int
        -sources: str
        -shard_by: str
        -reader: str
        -dataset: Reader
        -_all_files: List[str]
        -_actual_shard_by: str
        +__init__(sources, rank, world_size, ...)
        +_build()
        +_load_file_list()
        +_get_reader_class()
        +process(sample)* 
        +__iter__()
    }
    
    class RpcDataset {
        -server_endpoint: str
        -client_config: dict
        +__init__(server_endpoint, config)
        +__iter__()
        +_fetch_from_server()
    }
    
    %% 具体数据集实现
    class Qwen3Dataset {
        -system_prompt: str
        -tokenizer: AutoTokenizer
        -tokenizer_path: str
        +__init__(sources, system_prompt, tokenizer_path, ...)
        +process(sample)
    }
    class KeyeDataset {
        -system_prompt: str
        -tokenizer: AutoTokenizer
        -tokenizer_path: str
        +__init__(sources, system_prompt, tokenizer_path, ...)
        +process(sample)
    }
    class Qwen2VLDataset {
        -system_prompt: str
        -tokenizer: AutoTokenizer
        -tokenizer_path: str
        +__init__(sources, system_prompt, tokenizer_path, ...)
        +process(sample)
    }
    
    %% 包装和工具类
    
    class DataServer {
        -dataset: FileBasedDataset
        -port: int
        -serializer: Serializer
        +__init__(dataset, port)
        +start_server()
        +serve_data()
        +serialize_sample(sample)
    }
    
    %% 继承关系
    IterableDataset <|-- FileBasedDataset
    FileBasedDataset <|-- Qwen3Dataset
    FileBasedDataset <|-- Qwen2VLDataset
    FileBasedDataset <|-- KeyeDataset
    Reader <|-- ParquetReader
    Reader <|-- JsonlReader
    
    %% 组合关系
    FileBasedDataset *-- Reader : contains
    DataServer *-- FileBasedDataset : contains
    
    %% 依赖关系
    RpcDataset ..> DataServer : communicates with
    
    %% 注释和说明
    note for Reader "抽象迭代器类\n负责从文件中读取数据\n可实例化为具体Reader"
    
    note for FileBasedDataset "包含核心逻辑：\n• Data Sharding\n• Local Shuffle  \n• Checkpointing\n• Load Balance\n• Data Packing"
    
    note for RpcDataset "Server-Client模式\n直接从Server读取数据\n不处理分片和洗牌逻辑"
    
    note for DataServer "包含具体Dataset\n序列化数据\n通过RPC返回"